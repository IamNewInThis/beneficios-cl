# Copiar a .env y completar.

# --- Supabase ---
# Usa la SERVICE ROLE key (no la anon): el scraper escribe en la BD.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Anthropic (Claude) ---
# Se usa para EXTRAER los beneficios desde el texto scrapeado y
# devolverlos estructurados. Conseguila en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
