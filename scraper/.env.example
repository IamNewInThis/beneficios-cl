# Copiar a .env y completar.

# --- Supabase ---
# Usa la SERVICE ROLE key (no la anon): el scraper escribe en la BD.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Anthropic (Claude) ---
# Se usa para EXTRAER los beneficios desde el texto scrapeado y
# devolverlos estructurados. Conseguila en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Banco Falabella (Contentful) ---
# Token de Content Delivery (solo lectura) del espacio publico de Falabella.
# No es un secreto propio: es el mismo que su sitio expone al navegador.
FALABELLA_CONTENTFUL_SPACE_ID=p6eyia4djstu
FALABELLA_CONTENTFUL_TOKEN=tu-token-de-contentful
